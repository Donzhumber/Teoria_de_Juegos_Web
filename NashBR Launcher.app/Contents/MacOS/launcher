#!/bin/bash
# Carpeta del proyecto = carpeta que contiene este .app (nash_best_response_app)
HERE="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$HERE" || exit 1

alert() {
	if command -v osascript >/dev/null 2>&1; then
		osascript -e "display dialog \"$1\" buttons {\"OK\"} default button \"OK\" with title \"Nash BR\" with icon stop" 2>/dev/null || true
	fi
	echo "$1" >&2
}

# Por defecto intenta Google Chrome en rutas habituales; si no, navegador del sistema.
abrir_chrome_o_defecto() {
	local url="$1"
	local os_type
	os_type="$(uname -s 2>/dev/null || echo "")"
	if [[ "${os_type}" == "Darwin" ]]; then
		if /usr/bin/open -b com.google.Chrome "${url}" 2>/dev/null; then return 0; fi
		for chrome_app in \
			"/Applications/Google Chrome.app" \
			"${HOME}/Applications/Google Chrome.app" \
			"/Applications/Google Chrome Canary.app"; do
			if [[ -d "${chrome_app}" ]]; then
				/usr/bin/open -a "${chrome_app}" "${url}" 2>/dev/null && return 0
			fi
		done
		/usr/bin/open "${url}" 2>/dev/null && return 0
		return 1
	fi
	if [[ "${os_type}" == "Linux" ]]; then
		for c in google-chrome-stable google-chrome chromium chromium-browser; do
			if command -v "${c}" >/dev/null 2>&1; then
				"${c}" "${url}" 2>/dev/null && return 0
			fi
		done
	fi
	command -v xdg-open >/dev/null 2>&1 && xdg-open "${url}" 2>/dev/null && return 0
	return 1
}

if [[ ! -f "${HERE}/app.py" ]]; then
	alert "No se encontro app.py. Mantenga 'NashBR Launcher.app' dentro de la carpeta nash_best_response_app."
	exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
	alert "Instale Python 3 desde python.org e intente de nuevo."
	exit 1
fi

if ! python3 -c "import streamlit" 2>/dev/null; then
	alert "Instale dependencias en Terminal: cd \"${HERE}\" && python3 -m pip install -r requirements.txt"
	exit 1
fi

export MPLCONFIGDIR="${TMPDIR:-/tmp}/mpl-nash-$$"
mkdir -p "$MPLCONFIGDIR"

PORT="${NASH_BR_PORT:-8788}"
URL_LOCAL="http://127.0.0.1:${PORT}/"

EXTRA_ADDR=()
LAN_MSG=""
if [[ "${NASH_BR_LAN:-}" == "1" ]]; then
	EXTRA_ADDR=(--server.address "0.0.0.0")
	IP="$(ipconfig getifaddr en0 2>/dev/null || true)"
	[[ -z "${IP}" ]] && IP="$(ipconfig getifaddr en1 2>/dev/null || true)"
	if [[ -n "${IP}" ]]; then
		LAN_MSG="Otros equipos en la misma red pueden abrir: http://${IP}:${PORT}/"
	fi
fi

if command -v lsof >/dev/null 2>&1 && lsof -ti ":${PORT}" >/dev/null 2>&1; then
	lsof -ti ":${PORT}" | xargs kill -9 2>/dev/null || true
	sleep 1
fi

python3 -m streamlit run "${HERE}/app.py" \
	--server.headless true \
	--server.port "${PORT}" \
	--browser.gatherUsageStats false \
	"${EXTRA_ADDR[@]}" &
SPID=$!

OPENED=0
for _ in $(seq 1 80); do
	if curl -s -o /dev/null --connect-timeout 1 -w "%{http_code}" "${URL_LOCAL}" 2>/dev/null | grep -q 200; then
		abrir_chrome_o_defecto "${URL_LOCAL}" || /usr/bin/open "${URL_LOCAL}"
		OPENED=1
		if [[ -n "${LAN_MSG}" ]] && command -v osascript >/dev/null 2>&1; then
			osascript -e "display notification \"${LAN_MSG}\" with title \"Nash BR - modo red\"" 2>/dev/null || true
		fi
		break
	fi
	sleep 0.35
done

if [[ "${OPENED}" -ne 1 ]]; then
	alert "Streamlit no respondio en ${URL_LOCAL}. Revise que el puerto ${PORT} este libre o use NASH_BR_PORT."
	kill "${SPID}" 2>/dev/null || true
	exit 1
fi

wait "${SPID}"
